# Ghép vào block `server { ... }` phục vụ HTTPS cho API hoặc reverse proxy tới Uvicorn.
# Mục đích: upload file Excel lớn + import chạy lâu không bị nginx cắt (trùng HUONG_DAN_DEPLOY).
#
# QUAN TRỌNG — upload treo giữa chừng (vd. đứng ở 30–40%):
#   - client_body_timeout mặc định của nginx là 60s (hoặc tương đương): NẾU giữa hai lần nhận
#     chunk từ trình duyệt cách nhau > 60s → nginx đóng kết nối → upload “đứng”.
#   - Phải TĂNG client_body_timeout (và send_timeout) trong location hoặc server.

# Trong khối http { ... } (tùy VPS, một lần):
#   client_max_body_size 200m;
#
# upstream Uvicorn: thay cổng 8001 nếu khác.

# Export Excel toàn catalog — 3–15 phút trên VPS
location /api/v1/import-export/export/ {
    proxy_pass http://127.0.0.1:8001;
    proxy_http_version 1.1;
    proxy_set_header Host $host;
    proxy_set_header X-Real-IP $remote_addr;
    proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
    proxy_set_header X-Forwarded-Proto $scheme;

    proxy_connect_timeout 75s;
    proxy_send_timeout 900s;
    proxy_read_timeout 900s;
}

location /api/v1/import-export/import/ {
    # BẮT BUỘC — không có dòng này → nginx trả 413 khi file > ~1MB (mặc đnh)
    client_max_body_size 200m;

    proxy_pass http://127.0.0.1:8001;
    proxy_http_version 1.1;
    proxy_set_header Host $host;
    proxy_set_header X-Real-IP $remote_addr;
    proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
    proxy_set_header X-Forwarded-Proto $scheme;

    # Đọc body upload từ client — đủ lớn để mạng chậm / Wi‑Fi không bị cắt giữa chừng
    client_body_timeout 3600s;
    send_timeout 3600s;

    proxy_connect_timeout 60s;
    proxy_send_timeout 3600s;
    proxy_read_timeout 3600s;

    # Tùy chọn: stream body lên backend thay vì buffer hết (giảm RAM; có khi hết treo buffer)
    # proxy_request_buffering off;
}

# Đồng bộ Google Sheet (đồng bộ mã + đồng bộ sản phẩm) — ~30k hàng, 3–10 phút
location ~ ^/api/v1/import-export/(sync/google-sheet|cron/sync-google-sheet) {
    proxy_pass http://127.0.0.1:8001;
    proxy_http_version 1.1;
    proxy_set_header Host $host;
    proxy_set_header X-Real-IP $remote_addr;
    proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
    proxy_set_header X-Forwarded-Proto $scheme;

    proxy_connect_timeout 60s;
    proxy_send_timeout 3600s;
    proxy_read_timeout 3600s;
}

# Import thành viên / newsletter (Excel khách cũ) — cùng giới hạn body + timeout
location ~ ^/api/v1/(admin/users/import-file|newsletter/admin/import-file) {
    client_max_body_size 200m;

    proxy_pass http://127.0.0.1:8001;
    proxy_http_version 1.1;
    proxy_set_header Host $host;
    proxy_set_header X-Real-IP $remote_addr;
    proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
    proxy_set_header X-Forwarded-Proto $scheme;

    client_body_timeout 3600s;
    send_timeout 3600s;

    proxy_connect_timeout 60s;
    proxy_send_timeout 3600s;
    proxy_read_timeout 3600s;
}
