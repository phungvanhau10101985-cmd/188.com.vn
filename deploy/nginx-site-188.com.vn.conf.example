# Bản đầy đủ cho VPS — copy vào /etc/nginx/sites-enabled/188.com.vn
# (khớp cấu hình hiện tại + thêm location upload Excel lớn)
# Sau khi ghi: sudo nginx -t && sudo systemctl reload nginx

# 188.com.vn — proxy Next :3001, API :8001

server {
    listen 80;
    listen [::]:80;
    server_name 188.com.vn www.188.com.vn;
    return 301 https://188.com.vn$request_uri;
}

server {
    listen [::]:443 ssl http2;
    listen 443 ssl http2;
    server_name www.188.com.vn;

    ssl_certificate /etc/letsencrypt/live/188.com.vn/fullchain.pem;
    ssl_certificate_key /etc/letsencrypt/live/188.com.vn/privkey.pem;
    include /etc/letsencrypt/options-ssl-nginx.conf;
    ssl_dhparam /etc/letsencrypt/ssl-dhparams.pem;

    return 301 https://188.com.vn$request_uri;
}

server {
    listen [::]:443 ssl http2;
    listen 443 ssl http2;
    server_name 188.com.vn;

    ssl_certificate /etc/letsencrypt/live/188.com.vn/fullchain.pem;
    ssl_certificate_key /etc/letsencrypt/live/188.com.vn/privkey.pem;
    include /etc/letsencrypt/options-ssl-nginx.conf;
    ssl_dhparam /etc/letsencrypt/ssl-dhparams.pem;

    location = /health {
        proxy_pass http://127.0.0.1:8001/health;
        proxy_http_version 1.1;
        proxy_set_header Host $host;
        proxy_set_header X-Forwarded-Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
    }

    # Upload Excel lớn + không 413 — đặt TRƯỚC location /api/ (prefix dài hơn được ưu tiên)
    location /api/v1/import-export/import/ {
        client_max_body_size 200m;

        proxy_pass http://127.0.0.1:8001;
        proxy_http_version 1.1;
        proxy_set_header Host $host;
        proxy_set_header X-Forwarded-Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;

        client_body_timeout 3600s;
        send_timeout 3600s;

        proxy_connect_timeout 60s;
        proxy_send_timeout 3600s;
        proxy_read_timeout 3600s;
    }

    location /api/ {
        proxy_pass http://127.0.0.1:8001;
        proxy_http_version 1.1;
        proxy_set_header Host $host;
        proxy_set_header X-Forwarded-Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;

        # Tránh 504 Gateway Timeout khi API chờ PostgreSQL (pool đầy / query chậm).
        # Mặc định nginx thường ~60s — nhỏ hơn DATABASE_POOL_TIMEOUT hoặc thời gian chờ SP.
        proxy_connect_timeout 75s;
        proxy_send_timeout 180s;
        proxy_read_timeout 180s;
    }

    location / {
        proxy_pass http://127.0.0.1:3001;
        proxy_http_version 1.1;
        proxy_set_header Host $host;
        proxy_set_header X-Forwarded-Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
        proxy_set_header Upgrade $http_upgrade;
        proxy_set_header Connection "upgrade";
    }
}
