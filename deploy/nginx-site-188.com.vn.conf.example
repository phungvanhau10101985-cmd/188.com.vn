# Bản đầy đủ cho VPS — copy vào /etc/nginx/sites-enabled/188.com.vn
# (khớp cấu hình hiện tại + thêm location upload Excel lớn)
# Sau khi ghi: sudo nginx -t && sudo systemctl reload nginx

# 188.com.vn — proxy Next :3001, API :8001

server {
    listen 80;
    listen [::]:80;
    server_name 188.com.vn www.188.com.vn;
    return 301 https://188.com.vn$request_uri;
}

server {
    listen [::]:443 ssl http2;
    listen 443 ssl http2;
    server_name www.188.com.vn;

    ssl_certificate /etc/letsencrypt/live/188.com.vn/fullchain.pem;
    ssl_certificate_key /etc/letsencrypt/live/188.com.vn/privkey.pem;
    include /etc/letsencrypt/options-ssl-nginx.conf;
    ssl_dhparam /etc/letsencrypt/ssl-dhparams.pem;

    return 301 https://188.com.vn$request_uri;
}

server {
    listen [::]:443 ssl http2;
    listen 443 ssl http2;
    server_name 188.com.vn;

    ssl_certificate /etc/letsencrypt/live/188.com.vn/fullchain.pem;
    ssl_certificate_key /etc/letsencrypt/live/188.com.vn/privkey.pem;
    include /etc/letsencrypt/options-ssl-nginx.conf;
    ssl_dhparam /etc/letsencrypt/ssl-dhparams.pem;

    location = /health {
        proxy_pass http://127.0.0.1:8001/health;
        proxy_http_version 1.1;
        proxy_set_header Host $host;
        proxy_set_header X-Forwarded-Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
    }

    location = /health/db {
        proxy_pass http://127.0.0.1:8001/health/db;
        proxy_http_version 1.1;
        proxy_set_header Host $host;
        proxy_set_header X-Forwarded-Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
        proxy_connect_timeout 5s;
        proxy_read_timeout 15s;
    }

    # Monitor ngoài (UptimeRobot): 503 = pool DB kẹt — khách sắp không load được SP/menu
    location = /health/storefront {
        proxy_pass http://127.0.0.1:8001/health/storefront;
        proxy_http_version 1.1;
        proxy_set_header Host $host;
        proxy_set_header X-Forwarded-Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
        proxy_connect_timeout 5s;
        proxy_read_timeout 15s;
    }

    # Export Excel toàn catalog (~30k SP) — có thể 3–15 phút trên VPS
    location /api/v1/import-export/export/ {
        proxy_pass http://127.0.0.1:8001;
        proxy_http_version 1.1;
        proxy_set_header Host $host;
        proxy_set_header X-Forwarded-Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;

        proxy_connect_timeout 75s;
        proxy_send_timeout 900s;
        proxy_read_timeout 900s;
    }

    # Upload Excel lớn + không 413 — đặt TRƯỚC location /api/ (prefix dài hơn được ưu tiên)
    location /api/v1/import-export/import/ {
        client_max_body_size 200m;

        proxy_pass http://127.0.0.1:8001;
        proxy_http_version 1.1;
        proxy_set_header Host $host;
        proxy_set_header X-Forwarded-Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;

        client_body_timeout 3600s;
        send_timeout 3600s;

        proxy_connect_timeout 60s;
        proxy_send_timeout 3600s;
        proxy_read_timeout 3600s;
    }

    # Đồng bộ Google Sheet (mã + catalog ~30k SP) — có thể 3–10 phút
    location ~ ^/api/v1/import-export/(sync/google-sheet|cron/sync-google-sheet) {
        proxy_pass http://127.0.0.1:8001;
        proxy_http_version 1.1;
        proxy_set_header Host $host;
        proxy_set_header X-Forwarded-Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;

        proxy_connect_timeout 60s;
        proxy_send_timeout 3600s;
        proxy_read_timeout 3600s;
    }

    # Import khách cũ (admin/members) + newsletter — file Excel có thể vài MB / hàng chục nghìn dòng
    location ~ ^/api/v1/(admin/users/import-file|newsletter/admin/import-file) {
        client_max_body_size 200m;

        proxy_pass http://127.0.0.1:8001;
        proxy_http_version 1.1;
        proxy_set_header Host $host;
        proxy_set_header X-Forwarded-Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;

        client_body_timeout 3600s;
        send_timeout 3600s;

        proxy_connect_timeout 60s;
        proxy_send_timeout 3600s;
        proxy_read_timeout 3600s;
    }

    # Chống burst bot/crawler lên PDP API (đường nặng DB) — cần zone trong /etc/nginx/conf.d/188-rate-limit.conf
    location ~ ^/api/v1/products/by-slug/ {
        limit_req zone=api_byslug burst=40 nodelay;
        limit_req_status 429;

        proxy_pass http://127.0.0.1:8001;
        proxy_http_version 1.1;
        proxy_set_header Host $host;
        proxy_set_header X-Forwarded-Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
        proxy_connect_timeout 15s;
        proxy_send_timeout 60s;
        proxy_read_timeout 60s;
    }

    # Chặn quét dày các trang cluster products/facets (SEO bot)
    location ~ ^/api/v1/seo-clusters/.+/(products|facets)$ {
        limit_req zone=api_cluster_products burst=30 nodelay;
        limit_req_status 429;

        proxy_pass http://127.0.0.1:8001;
        proxy_http_version 1.1;
        proxy_set_header Host $host;
        proxy_set_header X-Forwarded-Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
        proxy_connect_timeout 15s;
        proxy_send_timeout 60s;
        proxy_read_timeout 60s;
    }

    # User-behavior là khối phụ UI: giới hạn nhẹ để không cướp pool khi bot/phóng nhiều tab
    location ~ ^/api/v1/user-behavior/ {
        limit_req zone=api_user_behavior burst=20 nodelay;
        limit_req_status 429;

        proxy_pass http://127.0.0.1:8001;
        proxy_http_version 1.1;
        proxy_set_header Host $host;
        proxy_set_header X-Forwarded-Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
        proxy_connect_timeout 15s;
        proxy_send_timeout 60s;
        proxy_read_timeout 60s;
    }

    location /api/ {
        proxy_pass http://127.0.0.1:8001;
        proxy_http_version 1.1;
        proxy_set_header Host $host;
        proxy_set_header X-Forwarded-Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;

        # Tránh 504 Gateway Timeout khi API chờ PostgreSQL / job nền.
        # Trước đây 180s — export catalog & một số admin API dễ vượt ngưỡng trên VPS.
        proxy_connect_timeout 75s;
        proxy_send_timeout 900s;
        proxy_read_timeout 900s;
    }

    location / {
        proxy_pass http://127.0.0.1:3001;
        proxy_http_version 1.1;
        proxy_set_header Host $host;
        proxy_set_header X-Forwarded-Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
        proxy_set_header Upgrade $http_upgrade;
        proxy_set_header Connection "upgrade";
        # Next proxy /api/v1 (dev) hoặc trang admin chờ lâu — đồng bộ với proxy_read_timeout export (900s)
        proxy_connect_timeout 75s;
        proxy_send_timeout 900s;
        proxy_read_timeout 900s;
        # Next App Router (RSC/streaming): tránh buffer làm treo hoặc HTML trống trên một số VPS
        proxy_buffering off;
    }
}
