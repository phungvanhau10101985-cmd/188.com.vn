# backend/.env.example - Copy to .env and fill in values
# ========================
# DATABASE - PostgreSQL (Production)
# ========================
# Format: postgresql://user:password@host:port/database
# Ví dụ local: postgresql://postgres:password@localhost:5432/188comvn
# Ví dụ cloud: postgresql://user:pass@db.xxx.supabase.co:5432/postgres
DATABASE_URL=postgresql://postgres:password@localhost:5432/188comvn

# Connection pool (PostgreSQL). VPS chia sẻ nanoai + Postgres local → 8 + 12 (tối đa 20 conn / 188-api).
# VPS chỉ 188 hoặc DB managed: có thể 10 + 15. Tổng mọi app < Postgres max_connections (~100).
DATABASE_POOL_SIZE=8
DATABASE_MAX_OVERFLOW=12
# Recycle 30 phút (1800s) — Postgres và một số firewall đóng connection idle 60 phút → recycle nhỏ hơn cho an toàn.
DATABASE_POOL_RECYCLE=1800
# Giây chờ lấy connection từ pool khi đã hết — fail-fast, tránh SSR Next treo.
DATABASE_POOL_TIMEOUT=20
# Cache cây menu + lưới /danh-muc (giây). Mặc định 300 — giảm query COUNT; menu có thể trễ tối đa 5 phút.
# CATEGORY_MENU_TREE_TTL_SECONDS=300
# CATEGORY_CATALOG_TILES_TTL_SECONDS=300

# Menu danh mục (GET /categories/from-products): cấp 3 cần ≥ số SP active này mới hiện; cấp 2 chỉ hiện khi còn ít nhất một L3 đạt ngưỡng.
# Mặc định 10; đặt 0 → chỉ ẩn nhánh 0 SP (mỗi L3 cần count > 0).
# CATEGORY_MENU_MIN_PRODUCT_COUNT=10

# ========================
# IMPORT EXCEL — tối đa dòng một lần + commit DB theo lô
# Gợi ý VPS: nginx client_max_body_size đủ lớn cho file .xlsx (vd. 150m); proxy_read_timeout nếu import lâu.
# ========================
MAX_EXCEL_IMPORT_ROWS=30000
EXCEL_IMPORT_COMMIT_BATCH_SIZE=250
# Lô có ≥ N dòng trong file import: không spawn thread Gemini SEO danh mục (đỡ spam API/quá lâu).
# Đặt 0 = vẫn spawn nền khi VPS + .env + admin đã bật tự động trong /admin/danh-muc-seo.
EXCEL_IMPORT_AUTO_SKIP_CATEGORY_SEO_MIN_ROWS=2500
# Cột Variant (JSON [{"name","img"},...]): dịch `name` sang tiếng Việt bằng DeepSeek trước khi ghi DB — cần DEEPSEEK_API_KEY.
# Import qua Hibox (hibox.mn): luôn dịch phiên bản màu sang tiếng Việt khi có DEEPSEEK_API_KEY (không phụ thuộc cờ dưới).
# Vipomall/Excel: bật EXCEL_VARIANT_COLORS_DEEPSEEK_TRANSLATE hoặc IMPORT_LINK_DEEPSEEK_TAXONOMY_ENABLED.
# Luôn dịch khi có CJK/Cyrillic hoặc nhãn Latin chưa có dấu tiếng Việt. Đặt EXCEL_VARIANT_COLORS_DEEPSEEK_FORCE_ALL=true để dịch mọi tên (tốn token).
EXCEL_VARIANT_COLORS_DEEPSEEK_TRANSLATE=false
EXCEL_VARIANT_COLORS_DEEPSEEK_FORCE_ALL=false
# --- Import Excel batch nhiều link 1688/Hibox (admin upload file link): nối sau restart API ---
# true = ~3 giây sau startup, quét file meta trong static/uploads/import_batches/ và chạy tiếp đợt còn draft chưa done/error.
# Ngoài ra có thể bấm «Chạy tiếp» trên trang Sản phẩm admin (POST /import-1688/jobs/excel-batches/{token}/resume).
IMPORT_1688_BATCH_RESUME_ON_STARTUP=false
# --- Gemini SEO danh mục (API + import Excel) ---
# Bước 1 (chỉ VPS): ENV=staging|production và đặt true. Bước 2 (bắt buộc): trên admin /admin/danh-muc-seo bật «Tự động Gemini»
# hoặc PUT /category-seo/app-settings (lưu bảng category_seo_settings). Thiếu bước 2 ⇒ luôn chỉ chạy tay.
CATEGORY_GEMINI_SEO_AUTO_ENABLED=false
# Biến cũ vẫn được đọc trên staging/production nếu chưa dùng tên CATEGORY_*:
# EXCEL_IMPORT_CATEGORY_SEO_BODY_ENABLED=true
# true = chỉ path đã đánh dấu «Gemini đích» (admin /category-seo/gemini-targets) mới được auto Gemini sau import/API SP.
CATEGORY_GEMINI_SEO_WHITELIST_ONLY=false

# ========================
# DATABASE - SQLite (Development, optional)
# ========================
# Bỏ comment dòng dưới để dùng SQLite thay vì PostgreSQL:
# DATABASE_URL=sqlite:///./app.db

# ========================
# PROJECT
# ========================
PROJECT_NAME=188-com-vn
# URL công khai storefront — ghép slug sản phẩm trong API (JSON slug đầy đủ), SEO, canonical.
WEBSITE_URL=https://188.com.vn
ENVIRONMENT=production
DEBUG=False

# ========================
# Admin — Kiểm tra nguồn hàng (batch từ DB, run-next-from-db)
# ========================
# Số ngày sau lần chạy một sản mới được xếp lại vào hàng chờ «vòng tròn» (mặc định 30).
# ADMIN_SOURCE_BATCH_SCAN_COOLDOWN_DAYS=30
# PDP traffic (user_product_views + guest_product_views trong N ngày gần) được ưu tiên so với SP chỉ xếp theo TTL thường.
# ADMIN_SOURCE_BATCH_TRAFFIC_VIEW_WINDOW_DAYS=30
# SP traffic: nếu vừa đánh batch (admin_source_batch_scanned_at) chưa qua N ngày thì không xếp hàng.
# ADMIN_SOURCE_BATCH_TRAFFIC_CHECK_GAP_DAYS=30

# ========================
# Gemini — SEO danh mục, gợi ý từ khóa, phân loại SP (cần GEMINI_API_KEY khi bật tính năng AI)
# Khuyến nghị: gemini-2.5-flash — gemini-2.0-flash trong .env cũ được config tự nâng lên 2.5
# ========================
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash

# DeepSeek (OpenAI-compatible) — dịch tên biến thể màu khi import Excel (EXCEL_VARIANT_COLORS_DEEPSEEK_TRANSLATE) hoặc khi import link có IMPORT_LINK_DEEPSEEK_TAXONOMY_ENABLED.
# DEEPSEEK_API_KEY=
# DEEPSEEK_API_URL=https://api.deepseek.com/v1/chat/completions
# DEEPSEEK_MODEL=deepseek-chat
# Import từ link 1688/Hibox: phân loại danh mục 3 cấp theo TÊN SP + taxonomy trong bảng categories (cần đã import taxonomy_import.xlsx + DEEPSEEK_API_KEY).
# IMPORT_LINK_DEEPSEEK_TAXONOMY_ENABLED=true
# IMPORT_LINK_DEEPSEEK_TAXONOMY_FORCE=false
# IMPORT_LINK_DEEPSEEK_GROUPS_FALLBACK_ENABLED=true
# (Khi không khớp từ-khóa nhóm đánh giá → gọi DeepSeek chọn mã whitelist; bật như taxonomy, cần DEEPSEEK_API_KEY.)
# Khi taxonomy có cả nhánh Nam/Nữ mà text không có giới tính: dùng Gemini phân tích ảnh đại diện (cần GEMINI_API_KEY).
# IMPORT_LINK_GEMINI_IMAGE_GENDER_ENABLED=true

# ========================
# SECURITY - BẮT BUỘC thay đổi khi deploy
# ========================
SECRET_KEY=your-secret-key-change-in-production
# Cron nội bộ (timeline vận chuyển, khuyến mãi, email CMSN): Bearer token bắt buộc. Không set = endpoint cron trả 503.
CRON_SECRET=your-cron-secret-change-in-production
# Crontab VPS: file mẫu đầy đủ deploy/crontab.188.com.vn.example — cài bằng sed + crontab - (xem comment trong file).
# Hoặc crontab -e và copy từng dòng:
# 0 9 * * * curl -sS -H "Authorization: Bearer YOUR_CRON_SECRET" "https://YOUR_API_HOST/api/v1/promotions/cron/daily-all"
# CART_ABANDON_EMAIL_ENABLED=true  # email «Bạn quên giỏ hàng» + link /cart khi tặng CARTSAVE188 (cần SMTP + FRONTEND_BASE_URL)
# NEWSLETTER_WELCOME_EMAIL_ENABLED=true  # email chào mừng sau đăng ký nhận tin footer
# Tra EMS vận chuyển (đơn chưa giao / chưa COD xong) — khuyến nghị 2 lần/ngày:
# 0 6,15 * * * curl -sS -H "Authorization: Bearer YOUR_CRON_SECRET" "https://YOUR_API_HOST/api/v1/orders/cron/refresh-ems-tracking"
# 30 3 * * * curl -sS -m 3600 -H "Authorization: Bearer YOUR_CRON_SECRET" "https://YOUR_API_HOST/api/v1/import-export/cron/sync-google-sheet-product-catalog"
# (6:00 sáng + 15:00 chiều; có thể tách 2 dòng crontab nếu muốn giờ khác)
#
# Fallback nội bộ (khuyên bật): nếu CRON ngoài trục trặc, backend vẫn tự enqueue tra EMS định kỳ.
EMS_TRACKING_INTERNAL_SCHEDULER_ENABLED=true
EMS_TRACKING_INTERNAL_INTERVAL_MINUTES=30
# EMS_SHIPPING_NOTIFY_ENABLED=True  # email + thông báo app khi tra EMS có trạng thái mới
# ORDER_SHIPPER_NOTIFY_ENABLED=True  # thông báo + email khi shop gửi shipper (kèm nhắc đánh giá)
# EMS_API_VERIFY_SSL=False  # api.myems.vn thiếu intermediate CA — để False để tra cứu ổn định
# PDP: gỡ URL ảnh 404 khỏi DB khi Next báo (trùng giá trị trong frontend/.env.local, server-only).
# Để trống hoặc không set = tắt endpoint purge.
# BROKEN_MEDIA_PURGE_SECRET=thay-bang-chuoi-ngau-nhien-dai

# ========================
# CORS — domain frontend được phép gọi API (Origin khớp thì trình duyệt mới gửi được Bearer…).
# ========================
BACKEND_CORS_ORIGINS=https://188.com.vn,https://www.188.com.vn
#
# Dev: Next chạy http://localhost:3001 nhưng NEXT_PUBLIC_API_BASE_URL trỏ API production
# → cross-origin. Phải THÊM localhost vào danh sách trên VPS rồi restart pm2, không chỉ next dev:
# BACKEND_CORS_ORIGINS=https://188.com.vn,https://www.188.com.vn,http://localhost:3001,http://127.0.0.1:3001
#
# Hoặc dev hoàn toàn local: NEXT_PUBLIC_API_BASE_URL=http://localhost:8001/api/v1 (không cần CORS production).
#
# Ngrok (tunnel trực tiếp tới FastAPI): thêm origin hoặc regex
# BACKEND_CORS_ORIGIN_REGEX=https://.*\.ngrok-free\.(dev|app)
#
# Ngrok tunnel tới Next :3001 — thêm origin cố định (đổi khi subdomain free đổi):
# BACKEND_CORS_ORIGINS=http://localhost:3001,http://127.0.0.1:3001,https://amia-canelike-exhibitively.ngrok-free.dev
# FRONTEND_BASE_URL=https://amia-canelike-exhibitively.ngrok-free.dev

# URL public của API (magic link email). Khi dev qua ngrok tới backend: đặt URL tunnel API
# BACKEND_PUBLIC_URL=https://yyyy.ngrok-free.app
# FRONTEND_BASE_URL=https://xxxx.ngrok-free.app

# ========================
# SEPAY — VietQR (qr.sepay.vn) + webhook tiền vào (đặt cọc đơn hàng)
# ========================
# Dashboard SePay — URL webhook HTTPS (nên ghi đủ kèm ?token= như trên my.sepay.vn).
# Ví dụ production:
# SEPAY_WEBHOOK_PUBLIC_URL=https://188.com.vn/api/sepay-webhook?token=YOUR_TOKEN_FROM_SEPAY
# Nếu tunnel ngrok trỏ vào Next (không trỏ thẳng FastAPI), dùng URL proxy: {FRONTEND}/api/sepay-webhook
# Ví dụ tunnel local (sửa khi đổi subdomain ngrok free):
# SEPAY_WEBHOOK_PUBLIC_URL=https://amia-canelike-exhibitively.ngrok-free.dev/api/sepay-webhook
# SEPAY_MERCHANT_ID=
#
# Webhook — chọn một trong các cách (khớp cấu hình trên my.sepay.vn → Webhooks):
# - API Key / ?token= trên URL: đặt token vào SEPAY_WEBHOOK_API_KEY (hoặc ghi đủ URL ở SEPAY_WEBHOOK_PUBLIC_URL)
# - Header: Authorization: Apikey <key>
SEPAY_WEBHOOK_API_KEY=
# - Hoặc HMAC: secret SePay + header x-sepay-signature (raw body). Ví dụ secret: ppsk_live_... / spsk_live_...
SEPAY_SECRET_KEY=
# false = không bắt buộc chữ ký nếu chưa cấu hình secret hoặc đang dùng Apikey; true = từ chối khi không xác thực được
SEPAY_REQUIRE_SIGNATURE=false
#
# Webhook "Không chứng thực" / không dùng Apikey: bật tin cậy IP SePay (đối chiếu allowlist sau khi đọc XFF/X-Real-IP)
SEPAY_WEBHOOK_TRUST_NO_AUTH_IP=false
# true = luôn đọc X-Forwarded-For + X-Real-IP (khi peer không bị nhận là private nhưng thực tế chỉ có Nginx gọi vào API)
SEPAY_WEBHOOK_TRUST_PROXY_HEADERS=false
# SEPAY_WEBHOOK_IP_ALLOWLIST=   # để trống = bộ IP SePay công bố; hoặc liệt kê CSV tuỳ chỉnh
#
# Chỉ dev: SEPAY_ALLOW_INSECURE_DEV=true (không dùng production)
#
# STK + mã ngân hàng hiển thị trên QR (trùng tài khoản đã kết nối SePay):
# SEPAY_QR_BANK_CODE=MBBank
# SEPAY_QR_ACCOUNT_NUMBER=
# SEPAY_QR_TEMPLATE=compact
#
# Nội dung CK (khớp SePay / VietQR): mặc định SEVQR + mã đơn — chỉnh nếu dashboard dùng tiền tố khác
# SEPAY_TRANSFER_PREFIX=SEVQR
# SEPAY_TRANSFER_BODY=order_code
# SEPAY_CONTENT_PREFIX=

# ========================
# NANOAI — tìm sản phẩm theo ảnh / vector (Messaging API, Bảng điều khiển NanoAI)
# Chỉ đặt trên backend; không đưa Bearer vào JS trình duyệt.
# ========================
# NANOAI_API_BASE=https://nanoai.vn
# NANOAI_PARTNER_ID=bffd3362-72d6-4690-9a18-5b69d77b30f0
# NANOAI_BEARER_TOKEN=

# ========================
# EMS — theo dõi vận đơn (public API: api.myems.vn/TrackAndTraceItemCode)
# ========================
# EMS_PUBLIC_API_BASE_URL=https://api.myems.vn
# EMS_TRACKING_LANGUAGE=0
# EMS_API_TIMEOUT_SECONDS=15
# Tuỳ chọn — API merchant cũ (ws.ems.com.vn), fallback khi public API không có dữ liệu:
# EMS_MERCHANT_TOKEN=
# EMS_LEGACY_API_BASE_URL=http://ws.ems.com.vn

# ========================
# OTP ĐĂNG KÝ - Zalo ưu tiên, fallback Firebase
# ========================
# Zalo OA (lấy từ https://developers.zalo.me): dùng để gửi OTP qua Zalo
# ZALO_OA_ID=
# ZALO_OA_SECRET=
# ZALO_OA_ACCESS_TOKEN=
# ZALO_REFRESH_TOKEN=
# ZALO_TEMPLATE_REGISTER=304254

# Firebase fallback: URL Cloud Function/webhook nhận POST JSON { "phone": "09xx", "otp": "123456" }
# Để trống = backend chỉ log OTP ra console (phù hợp dev/test)
# FIREBASE_OTP_WEBHOOK_URL=https://us-central1-your-project.cloudfunctions.net/sendOtp

# ========================
# GOOGLE OAUTH (cùng Client ID với NEXT_PUBLIC_GOOGLE_CLIENT_ID ở frontend)
# ========================
GOOGLE_CLIENT_ID=746017912204-oaonimp4dui2f0ar5aot352239png2q6.apps.googleusercontent.com

# ========================
# Web Push (PWA thông báo) — tạo bằng: npx web-push generate-vapid-keys
# Đổi private key thành PEM nếu pywebpush báo lỗi, hoặc dùng file .pem
# ========================
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_CLAIM_EMAIL=mailto:admin@example.com

# ========================
# SMTP — giống cấu hình Node/nodemailer (isSmtpConfigured = đủ 4 biến không rỗng)
#   SMTP_HOST, SMTP_USER, SMTP_PASS, và From: SMTP_FROM (khuyên) hoặc SENDER_EMAIL/EMAIL_FROM
# P.A / maychuemail: thường SMTPS port 465 (SMTP_SECURE=true) hoặc 587 + STARTTLS (SMTP_SECURE=false, EMAIL_USE_TLS=true)
# ========================
# SMTPS (ví dụ)
# SMTP_HOST=mail9005.maychuemail.com
# SMTP_PORT=465
# SMTP_SECURE=true
# SMTP_USER=thongbao@188.com.vn
# SMTP_PASS=your-mailbox-password
# SMTP_FROM="188.com.vn <thongbao@188.com.vn>"
# STARTTLS (ví dụ)
# SMTP_PORT=587
# SMTP_SECURE=false
# EMAIL_USE_TLS=True
#
SMTP_HOST=mail9209.maychuemail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
# From dạng "Tên <email@domain>" (ưu tiên). Nếu bỏ trống thì dùng SENDER_NAME + SENDER_EMAIL bên dưới
SMTP_FROM=
SENDER_NAME=188.com.vn
SENDER_EMAIL=chucmungsinhnhat@188.com.vn
REPLY_TO=chucmungsinhnhat@188.com.vn
EMAIL_USE_TLS=True
# Windows dev lỗi CERTIFICATE_VERIFY_FAILED (maychuemail port 465) → chỉ local: SMTP_SSL_VERIFY=false
# SMTP_SSL_VERIFY=true
# Email shop (CSV): nhận cảnh báo khi khách đặt cọc thành công (SePay / admin)
# ORDER_DEPOSIT_ALERT_EMAILS=cskh@188.com.vn
# Cảnh báo lỗi đăng nhập khách → email mọi tài khoản admin_users đang bật (mặc định bật)
# AUTH_LOGIN_FAILURE_ALERT_ENABLED=true
# AUTH_LOGIN_FAILURE_ALERT_COOLDOWN_SECONDS=180
# Tùy chọn: template / test
# COMPANY_NAME=
# COMPANY_PHONE=
# COMPANY_ADDRESS=
# WEBSITE_URL — xem mục PROJECT ở trên.
# EMAIL_SUBJECT_PREFIX=
# TEST_EMAIL=
# Gửi thử: python scripts/send_test_email.py to@example.com  (từ thư mục backend)

# ========================
# BUNNY.NET — Storage + Pull Zone (đọc trong app.core.config.Settings)
# ========================
# Dashboard → Storage zone + FTP/API password. Pull Zone (*.b-cdn.net) — custom hostname: CNAME → xxx.b-cdn.net
BUNNY_STORAGE_ZONE_NAME=188-com-vn-cdn
BUNNY_STORAGE_ACCESS_KEY=
# Public URL ảnh — trùng frontend NEXT_PUBLIC_CDN_URL và MERCHANT_FEED_IMAGE_BASE_URL khi không override
BUNNY_CDN_PUBLIC_BASE=https://188comvn.b-cdn.net
# Migrate ảnh backend/app/static: prefix folder trên Bunny (vd site)
BUNNY_UPLOAD_PATH_PREFIX=site
# Upload frontend/public: để trống = đường dẫn object khớp /images/...
BUNNY_WEB_PUBLIC_PREFIX=
# MERCHANT_FEED_IMAGE_BASE_URL=   # để trống trong app = BUNNY_CDN_PUBLIC_BASE — nếu khác host CDN, thêm biến đó để nhận URL xoá Bunny khi xoá SP
# BUNNY_DELETE_ON_PRODUCT_DELETE=false  # mặc định true — khi DELETE sản phẩm admin API, gọi Bunny Storage DELETE các object trùng host BUNNY/MERCHANT_FEED
# Scripts (từ thư mục backend):  python scripts/migrate_images_to_bunny.py
# python scripts/upload_frontend_public_to_bunny.py

# ========================
# PRODUCT IMAGE LOCALIZATION — Google Vision + DeepSeek + Gemini profile/cookie
# ========================
IMAGE_LOCALIZATION_ENABLED=True
IMAGE_LOCALIZATION_FULL_PIPELINE_ENABLED=True
# true = chỉ gọi Gemini/GPT sinh ảnh khi job có allow_ai_image_models hoặc product có product_info.image_localization.allow_ai_models=true
# IMAGE_LOCALIZATION_AI_IMAGE_EXPLICIT_ONLY=false
# true = admin có thể chạy job với Gemini/OpenAI ảnh; false (mặc định gợi ý) = chỉ OCR + DeepSeek + vẽ local (allow_ai_image_models phải false).
# IMAGE_LOCALIZATION_AI_IMAGE_JOBS_ALLOWED=false
# Module logic đã nằm trong backend; thường không cần set IMAGE_LOCALIZATION_TOOL_DIR.
# Không commit key. Đặt JSON service account (Vision API) trong backend/runtime/image_localization/
# (thư mục đã gitignore) hoặc đường dẫn tuyệt đối. Chạy API từ thư mục backend/ để path tương đối đúng.
# IMAGE_LOCALIZATION_GCP_KEY_FILE=runtime/image_localization/gcp-vision-service-account.json
# OCR Google Vision retry: không set hoặc 0 = vòng chờ chậm vô hạn (hành vi cũ; dễ treo tiến trình trên VPS nếu thiếu key).
# Đặt số như 12 để sau ~36 phút vẫn lỗi thì dừng và báo lỗi rõ trong log / job.
# IMAGE_LOCALIZATION_OCR_MAX_SLOW_WAITS=12
# Hoặc: GOOGLE_APPLICATION_CREDENTIALS=...
IMAGE_LOCALIZATION_BATCH_SIZE=10
IMAGE_LOCALIZATION_MAX_IMAGES_PER_PRODUCT=80
# Dọn file tạm temp_images/downloads còn sót (giờ). Mặc định 1 — gọi khi bắt đầu/kết thúc job.
# Cron tuần (lưới an toàn): deploy/crontab.188.com.vn.example — Chủ nhật 3:00, max_age_hours=24.
# IMAGE_LOCALIZATION_TEMP_CLEANUP_MAX_AGE_HOURS=1
# Local (DeepSeek + vẽ): để trống/off = luôn vẽ dù các bbox chữ dự kiến hơi đè (mặc định). Đặt số như 0.35 = bỏ vẽ, giữ ảnh gốc khi max(intersection/min_area hai hộp) > 0.35. Hành vi rất cũ ~0.01 gần như luôn bỏ vẽ.
# IMAGE_LOCALIZATION_LOCAL_OVERLAP_ABORT_THRESHOLD=
# Cookie JSON export hoặc Cookie header lưu qua API sẽ ghi vào file này.
# IMAGE_LOCALIZATION_GEMINI_COOKIE_FILE=gemini_cookies.json
# Chrome profile Playwright local; nếu trống backend dùng runtime/image_localization/chrome-profile.
# IMAGE_LOCALIZATION_CHROME_PROFILE_PATH=
# Chế độ Gemini cho bước sinh/sửa ảnh: web (cookie + Playwright) hoặc api (GEMINI_API_KEY + model Nano Banana).
# IMAGE_LOCALIZATION_GEMINI_MODE=web
# Có thể đặt openai để mặc định GPT Image (OPENAI_API_KEY) thay vì Gemini.
# IMAGE_LOCALIZATION_OPENAI_IMAGE_MODEL=gpt-image-2
# Snapshot / model khác (nếu API yêu cầu): ví dụ gpt-image-2-2026-04-21 hoặc gpt-image-1.5 khi /images/edits chưa nhận gpt-image-2.
# IMAGE_LOCALIZATION_OPENAI_IMAGE_TIMEOUT_SEC=300
# IMAGE_LOCALIZATION_GEMINI_IMAGE_MODEL=gemini-3-pro-image-preview
# Gemini API pipeline: chỉ imageSize 2K hoặc 4K; giá trị cũ 512/1K được nâng lên 2K. Tier Flex/Google queue rẻ không dùng cho job này.
# IMAGE_LOCALIZATION_GEMINI_API_DEFAULT_IMAGE_SIZE=2K
# OpenAI GPT Image: chỉ high | auto trong UI; không còn preset Flex/OpenAI tiết kiệm.
# IMAGE_LOCALIZATION_OPENAI_DEFAULT_IMAGE_QUALITY=high
# IMAGE_LOCALIZATION_GEMINI_API_TIMEOUT_SEC=300
# Playwright (Gemini Web) — một biến, hai kiểu triển khai:
# • true / mặc định → ẩn Chromium (server, không cửa sổ): IMAGE_LOCALIZATION_PLAYWRIGHT_HEADLESS=true
# • false → hiện cửa sổ (chỉ khi có DISPLAY/RDP để đăng nhập hoặc debug): IMAGE_LOCALIZATION_PLAYWRIGHT_HEADLESS=false
IMAGE_LOCALIZATION_PLAYWRIGHT_HEADLESS=true
IMAGE_LOCALIZATION_PLAYWRIGHT_TIMEOUT_MS=180000
# • Khi SSO mở accounts.google.com: bấm dòng có email này (list "Signed out"). Để trống = thử dòng Signed out / data-email đầu tiên.
# IMAGE_LOCALIZATION_GOOGLE_ACCOUNT_EMAIL=you@gmail.com
# Nếu true: đã có gemini_logged_in.marker trên Chrome profile Playwright → không merge cookie JSON từ admin (tránh file JSON cũ làm hỏng phiên đã đăng nhập).
# IMAGE_LOCALIZATION_GEMINI_SKIP_JSON_COOKIES_WHEN_PROFILE_MARKER=false

# ========================
# Đồng bộ danh sách sản phẩm lên Google Sheet
# Sau tạo / xóa / import Excel / đổi dữ liệu SP — API quét DB và chỉnh sheet:
# thiếu khóa trong cột A → thêm hàng; thừa (có trong sheet, không còn trong DB) → gỡ nội dung cột đồng bộ (A/B hoặc A–E), giữ cột khác.
# Bật API "Google Sheets" trên GCP; tạo Service Account JSON; Share spreadsheet cho email …@….iam.gserviceaccount.com — Quyền Editor.
# ========================
GOOGLE_SHEETS_SKU_SYNC_ENABLED=true
# Mặc định trong code = bật nếu không set biến; để tắt: false | 0 | off | disabled
# ID file: …/spreadsheets/d/<SPREADSHEET_ID>/edit…
GOOGLE_SHEETS_SKU_SPREADSHEET_ID=1Ofp4TnMRIoiBiZJUl2wfXAgsYwUIlJ98okYk5rgGXLU
# Tab sheet: …#gid=<SHEET_GID>
GOOGLE_SHEETS_SKU_SHEET_GID=1892071464
# Cột A: code | product_id | web_prefix (phần product_id trước «a188», không có a188 thì ghi nguyên product_id)
GOOGLE_SHEETS_SKU_SYNC_FIELD=web_prefix
# full = khóa + link + shop + giá + stamp (theo COLUMN_COUNT); key_time = chỉ cột A khóa + cột B thời điểm UTC (mỗi lần đồng bộ làm mới B)
GOOGLE_SHEETS_SKU_SYNC_ROW_MODE=key_time
# --- Bảng Google Sheet thứ hai (tuỳ chọn): khác khóa cột A (vd mã SKU `code`).
# Để trống GOOGLE_SHEETS_SKU_SPREADSHEET_ID_2 → chỉ đồng bộ primary.
# GOOGLE_SHEETS_SKU_SPREADSHEET_ID_2=1oO9uvoKKrD1jzvfCg9ZxxnoJT843lJ0oZM75077nQOI
# GOOGLE_SHEETS_SKU_SHEET_GID_2=191417507
# GOOGLE_SHEETS_SKU_SYNC_FIELD_2=code
# GOOGLE_SHEETS_SKU_SYNC_ROW_MODE_2=full
# Cột 1=chỉ A; 4=A–D: khóa A | link_default | shop | giá; 5=mặc định + cột E = thời điểm đồng bộ (UTC)
# GOOGLE_SHEETS_SKU_COLUMN_COUNT=5
# Tuỳ chọn: JSON riêng. Nếu trống: backend/runtime/image_localization/gcp-vision-service-account.json (nếu tồn tại), rồi GOOGLE_APPLICATION_CREDENTIALS, rồi IMAGE_LOCALIZATION_GCP_KEY_FILE
# GOOGLE_SHEETS_SKU_CREDENTIALS_PATH=
# Đồng bộ tay (admin): POST /api/v1/import-export/sync/google-sheet-skus
# Gộp nhiều thao tác tạo/sửa/xóa SP trong N giây → một lần gọi Google API (0 = mỗi lần chạy ngay).
# GOOGLE_SHEETS_SKU_SYNC_DEBOUNCE_SECONDS=45

# ========================
# Đồng bộ TOÀN BỘ catalog sản phẩm (41 cột Excel) lên Google Sheet — cron 3:30 sáng VN
# Share spreadsheet cho service account (Editor). Cron: GET /import-export/cron/sync-google-sheet-product-catalog
# ========================
GOOGLE_SHEETS_PRODUCT_CATALOG_SYNC_ENABLED=true
GOOGLE_SHEETS_PRODUCT_CATALOG_SPREADSHEET_ID=1iRaVEHjRupYRiB6sVv87m43EaZlR_I1laCuCL77CzRw
GOOGLE_SHEETS_PRODUCT_CATALOG_SHEET_GID=1079257836
# Windows dev lỗi CERTIFICATE_VERIFY_FAILED khi gọi Google API → chỉ local: GOOGLE_SHEETS_SSL_VERIFY=false
