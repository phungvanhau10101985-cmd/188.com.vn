# backend/.env.example - Copy to .env and fill in values
# ========================
# DATABASE - PostgreSQL (Production)
# ========================
# Format: postgresql://user:password@host:port/database
# Ví dụ local: postgresql://postgres:password@localhost:5432/188comvn
# Ví dụ cloud: postgresql://user:pass@db.xxx.supabase.co:5432/postgres
DATABASE_URL=postgresql://postgres:password@localhost:5432/188comvn

# Connection pool (PostgreSQL). Nhiều worker / traffic → tăng pool_size + max_overflow (nhớ max_connections Postgres).
# pool_size + max_overflow phải nhỏ hơn Postgres max_connections (mặc định 100). Tổng cho mọi app trên VPS.
DATABASE_POOL_SIZE=30
DATABASE_MAX_OVERFLOW=60
# Recycle 30 phút (1800s) — Postgres và một số firewall đóng connection idle 60 phút → recycle nhỏ hơn cho an toàn.
DATABASE_POOL_RECYCLE=1800
# Giây chờ lấy connection từ pool khi đã hết. Nhỏ hơn để fail-fast (~30s) thay vì 60s gây SSR Next chờ → trắng trang.
DATABASE_POOL_TIMEOUT=30

# Menu danh mục (GET /categories/from-products): chỉ hiển thị nhánh có số SP active **lớn hơn** số này.
# Mặc định 10 → có đủ 11 SP mới hiện; đặt 0 để giữ hành vi cũ (chỉ ẩn nhánh 0 SP).
# CATEGORY_MENU_MIN_PRODUCT_COUNT=10

# ========================
# IMPORT EXCEL — tối đa dòng một lần + commit DB theo lô
# Gợi ý VPS: nginx client_max_body_size đủ lớn cho file .xlsx (vd. 150m); proxy_read_timeout nếu import lâu.
# ========================
MAX_EXCEL_IMPORT_ROWS=30000
EXCEL_IMPORT_COMMIT_BATCH_SIZE=250
# Lô có ≥ N dòng trong file import: không spawn thread Gemini SEO danh mục (đỡ spam API/quá lâu).
# Đặt 0 = vẫn spawn nền khi VPS + .env + admin đã bật tự động trong /admin/danh-muc-seo.
EXCEL_IMPORT_AUTO_SKIP_CATEGORY_SEO_MIN_ROWS=2500
# --- Gemini SEO danh mục (API + import Excel) ---
# Bước 1 (chỉ VPS): ENV=staging|production và đặt true. Bước 2 (bắt buộc): trên admin /admin/danh-muc-seo bật «Tự động Gemini»
# hoặc PUT /category-seo/app-settings (lưu bảng category_seo_settings). Thiếu bước 2 ⇒ luôn chỉ chạy tay.
CATEGORY_GEMINI_SEO_AUTO_ENABLED=false
# Biến cũ vẫn được đọc trên staging/production nếu chưa dùng tên CATEGORY_*:
# EXCEL_IMPORT_CATEGORY_SEO_BODY_ENABLED=true
# true = chỉ path đã đánh dấu «Gemini đích» (admin /category-seo/gemini-targets) mới được auto Gemini sau import/API SP.
CATEGORY_GEMINI_SEO_WHITELIST_ONLY=false

# ========================
# DATABASE - SQLite (Development, optional)
# ========================
# Bỏ comment dòng dưới để dùng SQLite thay vì PostgreSQL:
# DATABASE_URL=sqlite:///./app.db

# ========================
# PROJECT
# ========================
PROJECT_NAME=188-com-vn
ENVIRONMENT=production
DEBUG=False

# ========================
# Gemini — SEO danh mục, gợi ý từ khóa, phân loại SP (cần GEMINI_API_KEY khi bật tính năng AI)
# Khuyến nghị: gemini-2.5-flash — gemini-2.0-flash trong .env cũ được config tự nâng lên 2.5
# ========================
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash

# ========================
# SECURITY - BẮT BUỘC thay đổi khi deploy
# ========================
SECRET_KEY=your-secret-key-change-in-production

# ========================
# CORS — domain frontend được phép gọi API (Origin khớp thì trình duyệt mới gửi được Bearer…).
# ========================
BACKEND_CORS_ORIGINS=https://188.com.vn,https://www.188.com.vn
#
# Dev: Next chạy http://localhost:3001 nhưng NEXT_PUBLIC_API_BASE_URL trỏ API production
# → cross-origin. Phải THÊM localhost vào danh sách trên VPS rồi restart pm2, không chỉ next dev:
# BACKEND_CORS_ORIGINS=https://188.com.vn,https://www.188.com.vn,http://localhost:3001,http://127.0.0.1:3001
#
# Hoặc dev hoàn toàn local: NEXT_PUBLIC_API_BASE_URL=http://localhost:8001/api/v1 (không cần CORS production).
#
# Ngrok (tunnel trực tiếp tới FastAPI): thêm origin hoặc regex
# BACKEND_CORS_ORIGIN_REGEX=https://.*\.ngrok-free\.(dev|app)
#
# Ngrok tunnel tới Next :3001 — thêm origin cố định (đổi khi subdomain free đổi):
# BACKEND_CORS_ORIGINS=http://localhost:3001,http://127.0.0.1:3001,https://amia-canelike-exhibitively.ngrok-free.dev
# FRONTEND_BASE_URL=https://amia-canelike-exhibitively.ngrok-free.dev

# URL public của API (magic link email). Khi dev qua ngrok tới backend: đặt URL tunnel API
# BACKEND_PUBLIC_URL=https://yyyy.ngrok-free.app
# FRONTEND_BASE_URL=https://xxxx.ngrok-free.app

# ========================
# SEPAY — VietQR (qr.sepay.vn) + webhook tiền vào (đặt cọc đơn hàng)
# ========================
# Dashboard SePay — URL webhook HTTPS. Mặc định: {BACKEND_PUBLIC_URL}/api/v1/sepay/webhook
# Nếu tunnel ngrok trỏ vào Next (không trỏ thẳng FastAPI), dùng URL proxy: {FRONTEND}/api/sepay-webhook
# Ví dụ tunnel local (sửa khi đổi subdomain ngrok free):
# SEPAY_WEBHOOK_PUBLIC_URL=https://amia-canelike-exhibitively.ngrok-free.dev/api/sepay-webhook
# SEPAY_MERCHANT_ID=
#
# Webhook — chọn một trong các cách (khớp cấu hình trên my.sepay.vn → Webhooks):
# - API Key: SePay gửi Authorization: Apikey <key>
SEPAY_WEBHOOK_API_KEY=
# - Hoặc HMAC: secret SePay + header x-sepay-signature (raw body). Ví dụ secret: ppsk_live_... / spsk_live_...
SEPAY_SECRET_KEY=
# false = không bắt buộc chữ ký nếu chưa cấu hình secret hoặc đang dùng Apikey; true = từ chối khi không xác thực được
SEPAY_REQUIRE_SIGNATURE=false
#
# Webhook "Không chứng thực" / không dùng Apikey: bật tin cậy IP SePay (đối chiếu allowlist sau khi đọc XFF/X-Real-IP)
SEPAY_WEBHOOK_TRUST_NO_AUTH_IP=false
# true = luôn đọc X-Forwarded-For + X-Real-IP (khi peer không bị nhận là private nhưng thực tế chỉ có Nginx gọi vào API)
SEPAY_WEBHOOK_TRUST_PROXY_HEADERS=false
# SEPAY_WEBHOOK_IP_ALLOWLIST=   # để trống = bộ IP SePay công bố; hoặc liệt kê CSV tuỳ chỉnh
#
# Chỉ dev: SEPAY_ALLOW_INSECURE_DEV=true (không dùng production)
#
# STK + mã ngân hàng hiển thị trên QR (trùng tài khoản đã kết nối SePay):
# SEPAY_QR_BANK_CODE=MBBank
# SEPAY_QR_ACCOUNT_NUMBER=
# SEPAY_QR_TEMPLATE=compact
#
# Nội dung CK (khớp SePay / VietQR): mặc định SEVQR + mã đơn — chỉnh nếu dashboard dùng tiền tố khác
# SEPAY_TRANSFER_PREFIX=SEVQR
# SEPAY_TRANSFER_BODY=order_code
# SEPAY_CONTENT_PREFIX=

# ========================
# NANOAI — tìm sản phẩm theo ảnh / vector (Messaging API, Bảng điều khiển NanoAI)
# Chỉ đặt trên backend; không đưa Bearer vào JS trình duyệt.
# ========================
# NANOAI_API_BASE=https://nanoai.vn
# NANOAI_PARTNER_ID=bffd3362-72d6-4690-9a18-5b69d77b30f0
# NANOAI_BEARER_TOKEN=

# ========================
# OTP ĐĂNG KÝ - Zalo ưu tiên, fallback Firebase
# ========================
# Zalo OA (lấy từ https://developers.zalo.me): dùng để gửi OTP qua Zalo
# ZALO_OA_ID=
# ZALO_OA_SECRET=
# ZALO_OA_ACCESS_TOKEN=
# ZALO_REFRESH_TOKEN=
# ZALO_TEMPLATE_REGISTER=304254

# Firebase fallback: URL Cloud Function/webhook nhận POST JSON { "phone": "09xx", "otp": "123456" }
# Để trống = backend chỉ log OTP ra console (phù hợp dev/test)
# FIREBASE_OTP_WEBHOOK_URL=https://us-central1-your-project.cloudfunctions.net/sendOtp

# ========================
# GOOGLE OAUTH (cùng Client ID với NEXT_PUBLIC_GOOGLE_CLIENT_ID ở frontend)
# ========================
GOOGLE_CLIENT_ID=746017912204-oaonimp4dui2f0ar5aot352239png2q6.apps.googleusercontent.com

# ========================
# Web Push (PWA thông báo) — tạo bằng: npx web-push generate-vapid-keys
# Đổi private key thành PEM nếu pywebpush báo lỗi, hoặc dùng file .pem
# ========================
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_CLAIM_EMAIL=mailto:admin@example.com

# ========================
# SMTP — giống cấu hình Node/nodemailer (isSmtpConfigured = đủ 4 biến không rỗng)
#   SMTP_HOST, SMTP_USER, SMTP_PASS, và From: SMTP_FROM (khuyên) hoặc SENDER_EMAIL/EMAIL_FROM
# P.A / maychuemail: thường SMTPS port 465 (SMTP_SECURE=true) hoặc 587 + STARTTLS (SMTP_SECURE=false, EMAIL_USE_TLS=true)
# ========================
# SMTPS (ví dụ)
# SMTP_HOST=mail9005.maychuemail.com
# SMTP_PORT=465
# SMTP_SECURE=true
# SMTP_USER=thongbao@188.com.vn
# SMTP_PASS=your-mailbox-password
# SMTP_FROM="188.com.vn <thongbao@188.com.vn>"
# STARTTLS (ví dụ)
# SMTP_PORT=587
# SMTP_SECURE=false
# EMAIL_USE_TLS=True
#
SMTP_HOST=mail9209.maychuemail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
# From dạng "Tên <email@domain>" (ưu tiên). Nếu bỏ trống thì dùng SENDER_NAME + SENDER_EMAIL bên dưới
SMTP_FROM=
SENDER_NAME=188.com.vn
SENDER_EMAIL=chucmungsinhnhat@188.com.vn
REPLY_TO=chucmungsinhnhat@188.com.vn
EMAIL_USE_TLS=True
# Email shop (CSV): nhận cảnh báo khi khách đặt cọc thành công (SePay / admin)
# ORDER_DEPOSIT_ALERT_EMAILS=cskh@188.com.vn
# Tùy chọn: template / test
# COMPANY_NAME=
# COMPANY_PHONE=
# COMPANY_ADDRESS=
# WEBSITE_URL=https://188.com.vn
# EMAIL_SUBJECT_PREFIX=
# TEST_EMAIL=
# Gửi thử: python scripts/send_test_email.py to@example.com  (từ thư mục backend)

# ========================
# BUNNY.NET — Storage + Pull Zone (đọc trong app.core.config.Settings)
# ========================
# Dashboard → Storage zone + FTP/API password. Pull Zone (*.b-cdn.net) — custom hostname: CNAME → xxx.b-cdn.net
BUNNY_STORAGE_ZONE_NAME=188-com-vn-cdn
BUNNY_STORAGE_ACCESS_KEY=
# Public URL ảnh — trùng frontend NEXT_PUBLIC_CDN_URL và MERCHANT_FEED_IMAGE_BASE_URL khi không override
BUNNY_CDN_PUBLIC_BASE=https://188comvn.b-cdn.net
# Migrate ảnh backend/app/static: prefix folder trên Bunny (vd site)
BUNNY_UPLOAD_PATH_PREFIX=site
# Upload frontend/public: để trống = đường dẫn object khớp /images/...
BUNNY_WEB_PUBLIC_PREFIX=
# MERCHANT_FEED_IMAGE_BASE_URL=   # để trống trong app = BUNNY_CDN_PUBLIC_BASE
# Scripts (từ thư mục backend):  python scripts/migrate_images_to_bunny.py
# python scripts/upload_frontend_public_to_bunny.py
