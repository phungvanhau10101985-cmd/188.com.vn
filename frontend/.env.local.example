# Sao chép thành .env.local (file thật không vào git).
#
# Ngrok → Next dev (cổng 3001):
#   ngrok http 3001
# Đăng ký SePay webhook:
#   https://amia-canelike-exhibitively.ngrok-free.dev/api/sepay-webhook
#
API_INTERNAL_ORIGIN=http://127.0.0.1:8001
NEXT_PUBLIC_SITE_URL=https://amia-canelike-exhibitively.ngrok-free.dev
NEXT_PUBLIC_DOMAIN=https://amia-canelike-exhibitively.ngrok-free.dev
# Proxy /api/v1 trong Next là mặc định (bỏ NEXT_PUBLIC_API_NEXT_PROXY hoặc ≠ "0").
# Muốn gọi trực tiếp :8001 từ browser: NEXT_PUBLIC_API_NEXT_PROXY=0
# Khi proxy, URL /static từ FastAPI (dev): NEXT_PUBLIC_FASTAPI_ORIGIN=http://127.0.0.1:8001 (để trống cũng mặc định cổng 8001 trong code).

# Meta Conversion API — trùng giá trị với backend/.env (chỉ server Next đọc, không NEXT_PUBLIC)
# FACEBOOK_CAPI_INGEST_SECRET=changeme_same_as_backend

# Đăng nhập Google (One Tap / nút Gmail) — bắt buộc có tiền tố NEXT_PUBLIC_
# Giá trị phải trùng GOOGLE_CLIENT_ID trong backend/.env
# NEXT_PUBLIC_GOOGLE_CLIENT_ID=xxxx.apps.googleusercontent.com

# Giảm preview video trong Google SERP cho trang chi tiết sản phẩm (robots googleBot max-video-preview=0).
# Không chặn bot tải file .mp4 nếu URL CDN vẫn public trong HTML — muốn chặn triệt để cần URL ký/token trên CDN.
# SEO_BLOCK_BOT_VIDEO_PREVIEW=1
