# Sao chép thành `.env.local` (ghi đè mọi file .env khác).
# Hiện repo có `.env.development` với PORT=3001 — chỉ cần không đặt PORT khác trong .env.local.
PORT=3001

# API backend (dev local)
# NEXT_PUBLIC_API_BASE_URL=http://localhost:8001/api/v1

# Google Ads AW- — chỉ dùng khi API `/embed-codes/public` **không** trả về `google_ads_aw_ids` (backend cũ). Khi API có trường này, `send_to` chỉ theo mã nhúng admin (google/ads).
# NEXT_PUBLIC_GOOGLE_ADS_AW_ID=AW-XXXXXXXXX

# Mỗi dòng: AW-XXXXXXXX/label (send_to trong Google Ads). Có thể dán kèm «send_to:» / snippet — backend/FE tự tách mã.
# Chỉ dùng các biến dưới khi không cấu hình qua admin hoặc backend cũ không trả đủ object.
# NEXT_PUBLIC_GOOGLE_ADS_PDP_CONVERSION_SEND_TO=AW-882019087/ggduCMPp2KccEI-WyqQD
# NEXT_PUBLIC_GOOGLE_ADS_ADD_TO_CART_CONVERSION_SEND_TO=
# NEXT_PUBLIC_GOOGLE_ADS_BEGIN_CHECKOUT_CONVERSION_SEND_TO=
# NEXT_PUBLIC_GOOGLE_ADS_DEPOSIT_PAGE_CONVERSION_SEND_TO=
# NEXT_PUBLIC_GOOGLE_ADS_PURCHASE_CONVERSION_SEND_TO=

# CwCD — lượt chuyển đổi có dữ liệu giỏ hàng (chiết khấu tự động Merchant Center)
NEXT_PUBLIC_GOOGLE_MERCHANT_CENTER_ID=5672138097
NEXT_PUBLIC_GOOGLE_FEED_COUNTRY=VN
NEXT_PUBLIC_GOOGLE_FEED_LANGUAGE=vi
# Khớp backend MERCHANT_FEED_CURRENCY (mặc định VND nếu bỏ trống)
# NEXT_PUBLIC_GOOGLE_FEED_CURRENCY=VND

# Đăng nhập Gmail — trùng với GOOGLE_CLIENT_ID (backend/.env), không có NEXT_PUBLIC_ thì trình duyệt không thấy
# NEXT_PUBLIC_GOOGLE_CLIENT_ID=xxxx.apps.googleusercontent.com

# --- Google Sheet đồng bộ (hai link tuỳ chọn; quyền ghi = backend GOOGLE_SHEETS_SKU_* + _2)
# Link mở tab trong admin; khớp thứ tự backend (primary = thường web_prefix, _2 = thường code/SKU).
NEXT_PUBLIC_GOOGLE_SHEETS_EDITOR_URL=https://docs.google.com/spreadsheets/d/1Ofp4TnMRIoiBiZJUl2wfXAgsYwUIlJ98okYk5rgGXLU/edit?gid=1892071464
NEXT_PUBLIC_GOOGLE_SHEETS_SPREADSHEET_ID=1Ofp4TnMRIoiBiZJUl2wfXAgsYwUIlJ98okYk5rgGXLU
NEXT_PUBLIC_GOOGLE_SHEETS_SHEET_GID=1892071464
NEXT_PUBLIC_GOOGLE_SHEETS_EDITOR_URL_2=https://docs.google.com/spreadsheets/d/1oO9uvoKKrD1jzvfCg9ZxxnoJT843lJ0oZM75077nQOI/edit?gid=191417507
NEXT_PUBLIC_GOOGLE_SHEETS_SPREADSHEET_ID_2=1oO9uvoKKrD1jzvfCg9ZxxnoJT843lJ0oZM75077nQOI
NEXT_PUBLIC_GOOGLE_SHEETS_SHEET_GID_2=191417507
# 1 = hiện nút «Đồng bộ mã» trên /admin/products (0/false = ẩn)
NEXT_PUBLIC_ADMIN_GOOGLE_SHEET_SYNC=1
# Sheet sản phẩm đầy đủ (41 cột) — khớp GOOGLE_SHEETS_PRODUCT_CATALOG_* trên backend
NEXT_PUBLIC_GOOGLE_SHEETS_CATALOG_EDITOR_URL=https://docs.google.com/spreadsheets/d/1iRaVEHjRupYRiB6sVv87m43EaZlR_I1laCuCL77CzRw/edit?gid=1079257836
# 1 = hiện nút «Đồng bộ sản phẩm» trên /admin/products (0/false = ẩn)
NEXT_PUBLIC_ADMIN_GOOGLE_SHEET_CATALOG_SYNC=1

# 1/true = hạn chế preview video trong Google SERP (trang /products/...); không thay cho chặn CDN mp4 public.
# SEO_BLOCK_BOT_VIDEO_PREVIEW=1
